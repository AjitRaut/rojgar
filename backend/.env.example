# Application
APP_NAME=Rojgar API
APP_ENV=development
APP_DEBUG=True
APP_VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rojgar_find

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-secret-min-32-characters-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# OpenAI (put your real key here)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# File Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5


# SMTP (Gmail App Password - FREE)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Rojgar
SMTP_USE_TLS=True